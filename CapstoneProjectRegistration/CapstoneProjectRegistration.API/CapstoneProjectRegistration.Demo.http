@host = https://localhost:7259
@token = <paste_jwt_from_token_response>

### ========================================
### 0) Issue JWT — dev seed accounts (password DevPass@1 for all)
###    Admin | Lecturer | Student
### ========================================

# @name adminToken
POST {{host}}/api/v1/authentication/token
Content-Type: application/json

{
  "email": "admin@gmail.com",
  "password": "DevPass@1"
}

###
# @name lecturerToken
POST {{host}}/api/v1/authentication/token
Content-Type: application/json

{
  "email": "lecturer1@gmail.com",
  "password": "DevPass@1"
}

###
# @name studentToken
POST {{host}}/api/v1/authentication/token
Content-Type: application/json

{
  "email": "thinhpdqse171589@fpt.edu.vn",
  "password": "DevPass@1"
}

### ========================================
### A. QUICK CHECK SEEDED DATA
### ========================================

### 1) Active registration period (from seed)
GET {{host}}/api/v1/registration-periods/active

### 2) List all topics (seed includes multiple statuses)
GET {{host}}/api/v1/topics

### 3) Get approved seeded topic details
GET {{host}}/api/v1/topics/1001

### 4) Review summary — requires Lecturer or Admin JWT (not Student)
GET {{host}}/api/v1/topics/1002/reviews/summary
Authorization: Bearer {{token}}

### ========================================
### B. DEMO FLOW 1 - HAPPY PATH (APPROVE -> PUBLIC)
### Use Admin JWT for assign/publish; Lecturer or Admin for reviews/summary
### ========================================

### 5) Create topic (Admin or Lecturer)
POST {{host}}/api/v1/topics
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "englishName": "Capstone Registration Portal",
  "vietnameseName": "Cong thong tin dang ky de tai",
  "topicCode": "SU26SE010",
  "description": "Build a three tier RESTful API system for topic registration and review assignment.",
  "semesterId": 1,
  "registrationPeriodId": 1,
  "creatorId": 1
}

### 6) Assign two reviewers (Admin only) — REST: PUT .../reviewers
PUT {{host}}/api/v1/topics/1003/reviewers
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reviewer1Id": 2,
  "reviewer2Id": 3
}

### 7) Reviewer 1 approves
POST {{host}}/api/v1/topics/1003/reviews
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reviewerId": 2,
  "decision": "Approved",
  "comment": "Good scope and feasible timeline."
}

### 8) Reviewer 2 approves
POST {{host}}/api/v1/topics/1003/reviews
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reviewerId": 3,
  "decision": "Approved",
  "comment": "Approved with minor wording improvements."
}

### 9) Review summary (should be Approved)
GET {{host}}/api/v1/topics/1003/reviews/summary
Authorization: Bearer {{token}}

### 10) Publish topic (Admin only)
POST {{host}}/api/v1/topics/1003/publication
Authorization: Bearer {{token}}

### ========================================
### C. DEMO FLOW 2 - REJECT PATH
### ========================================

### 11) Create another topic
POST {{host}}/api/v1/topics
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "englishName": "Student Topic Matching Assistant",
  "vietnameseName": "Tro ly doi soat de tai cho sinh vien",
  "topicCode": "SU26SE011",
  "description": "Support students in searching and comparing capstone topics.",
  "semesterId": 1,
  "registrationPeriodId": 1,
  "creatorId": 4
}

### 12) Assign reviewers (Admin)
PUT {{host}}/api/v1/topics/1004/reviewers
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reviewer1Id": 2,
  "reviewer2Id": 3
}

### 13) Reviewer 1 rejects
POST {{host}}/api/v1/topics/1004/reviews
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reviewerId": 2,
  "decision": "Rejected",
  "comment": "Problem statement is not clear enough."
}

### 14) Reviewer 2 approves
POST {{host}}/api/v1/topics/1004/reviews
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "reviewerId": 3,
  "decision": "Approved",
  "comment": "Can continue with stronger scope definition."
}

### 15) Summary (should be Rejected)
GET {{host}}/api/v1/topics/1004/reviews/summary
Authorization: Bearer {{token}}

### 16) Publish rejected topic (should fail)
POST {{host}}/api/v1/topics/1004/publication
Authorization: Bearer {{token}}

### ========================================
### D. AUXILIARY APIS
### ========================================

### 17) Similarity check (Lecturer or Admin)
POST {{host}}/api/v1/topics/similarity-checks
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "englishName": "BoneVisQA Interactive Learning",
  "vietnameseName": "BoneVisQA Hoi Dap Truc Quan",
  "description": "Interactive VQA and RAG based learning system for bone diseases."
}

### 18) Create registration period (Admin only)
POST {{host}}/api/v1/registration-periods
Authorization: Bearer {{token}}
Content-Type: application/json

{
  "name": "Fall 2026",
  "startDate": "2026-09-01T00:00:00",
  "endDate": "2026-09-30T23:59:59",
  "semesterId": 1
}
